# Google Health / OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SSM_PARAMETER_NAME=/fitsync/google_health_refresh_token

# Hevy
HEVY_API_KEY=your_hevy_api_key_here

# Slack
# Bot user OAuth token from your Slack app (scope: chat:write)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Channel ID (preferred, e.g. C0123456789) or name (e.g. #workouts). Invite the bot to the channel first.
SLACK_CHANNEL=your-channel-id-or-name

# Local / dev only
USER_PASSWORD=
AWS_WEBHOOK_URL=
